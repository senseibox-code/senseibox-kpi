[Unit]
Description=Senseibox KPI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=senseibox
Group=senseibox
WorkingDirectory=/opt/senseibox-kpi
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/senseibox-kpi/.venv/bin/system-dashboard --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full

[Install]
WantedBy=multi-user.target
