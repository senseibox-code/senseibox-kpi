[Unit]
Description=System Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=dashboard
Group=dashboard
WorkingDirectory=/opt/system-dashboard
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/system-dashboard/.venv/bin/system-dashboard --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
